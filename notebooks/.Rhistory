library(tidyverse)
# -----
DATA_DIR="/home/magnolia/DataScience/Stellar_Class/data"
TRAIN_CSV="/train.csv"
TEST_CSV="/test.csv"
train=read_delim(file.path(DATA_DIR, TRAIN_CSV), delim = ',')
features<-colnames(train)
target<-train$class
train
train %>%
ggplot(aes(x=alpha, fill=spectral_type)) +
geom_histogram()
train %>%
ggplot(aes(x=delta, fill=spectral_type)) +
geom_histogram()
train %>%
ggplot(aes(x=u, fill=spectral_type)) +
geom_histogram()
train
